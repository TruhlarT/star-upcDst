bemc_energy_seed          0.3
bemc_energy_add           0.001
bemc_energy_threshold_all 0.1

#directory for merged outputs, relative to top
outdir   merge_files

#name for merged outputs
outfile  StUPCRP_production.root

#list of output files
outlist  Part3.list
